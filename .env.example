# ============================================================
# Blythe Doll Generator — переменные окружения
# Скопируй этот файл в .env и заполни своими значениями
# НИКОГДА не коммить .env в git!
# ============================================================

# Telegram (опционально — для уведомлений)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Домен (для CORS)
ALLOWED_DOMAIN=blythello.com

# Название проекта
PROJECT_NAME=Blythello

# Порт (по умолчанию 8000 локально, 7860 на HF/Render)
PORT=8000

# URL для heartbeat (чтобы Render не засыпал, опционально)
# HEARTBEAT_URL=https://your-service.onrender.com/health
